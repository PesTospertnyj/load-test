# Server Configuration
SERVER_PORT=8080
ENVIRONMENT=development

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=booksapi
POSTGRES_PASSWORD=booksapi_password
POSTGRES_DB=booksapi
POSTGRES_SSLMODE=disable

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=5m

# Migration Configuration
MIGRATION_PATH=file://db/migrations

# OpenAPI/Swagger
SWAGGER_ENABLED=true
